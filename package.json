{
  "name": "rubencdblog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "sanity:typegen": "sanity typegen generate",
    "analyze": "ANALYZE=true next build",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@portabletext/react": "latest",
    "@portabletext/types": "^4.0.1",
    "@sanity/client": "^7.20.0",
    "@sanity/document-internationalization": "^6.0.3",
    "@sanity/image-url": "latest",
    "@sanity/vision": "latest",
    "@tailwindcss/typography": "^0.5.19",
    "clsx": "latest",
    "groq": "latest",
    "gsap": "^3.14.2",
    "motion": "latest",
    "next": "latest",
    "next-intl": "^4.8.3",
    "next-sanity": "latest",
    "react": "latest",
    "react-dom": "latest",
    "sanity": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "latest",
    "@commitlint/config-conventional": "latest",
    "@eslint/eslintrc": "latest",
    "@next/bundle-analyzer": "latest",
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "@vitest/coverage-v8": "latest",
    "eslint": "9",
    "eslint-config-next": "latest",
    "husky": "latest",
    "jsdom": "latest",
    "lint-staged": "latest",
    "postcss": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
